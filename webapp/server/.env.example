# Database (Local SQLite)
DATABASE_URL="file:./dev.db"

# JWT Secret (Used for any future user authentication)
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY"

# External APIs needed to run this application:

# 1. Polygon.io (REQUIRED)
# Used for real-time Options Chains, Pricing, and Greeks.
# Get it here: https://polygon.io/ (Options tier recommended, Free tier works with limitations)
POLYGON_API_KEY="YOUR_POLYGON_API_KEY"

# 2. FRED - Federal Reserve Economic Data (REQUIRED)
# Used for the Macro View indicators (Interest Rates, CPI Inflation) on the homepage.
# Get it here: https://fredaccount.stlouisfed.org/apikeys (Free)
FRED_API_KEY="YOUR_FRED_API_KEY"

# 3. Finnhub.io (REQUIRED)
# Used for the Trending News and Ticker-specific Latest Intelligence feeds.
# Get it here: https://finnhub.io/register (Free)
FINNHUB_API_KEY="YOUR_FINNHUB_API_KEY"

# 4. Tiingo (Optional Fallback)
# Used as a fallback source for basic stock quotes if Polygon is unreachable.
# Get it here: https://api.tiingo.com/ (Free)
TIINGO_API_KEY="YOUR_TIINGO_API_KEY"

# 5. Alpaca (Optional / Future Use)
# Used for advanced paper trading order execution if bypassing the local database.
# Get it here: https://app.alpaca.markets/paper/dashboard/overview (Free)
ALPACA_API_KEY="YOUR_ALPACA_API_KEY"
ALPACA_SECRET_KEY="YOUR_ALPACA_SECRET_KEY"
ALPACA_PAPER=true

# App Configuration
PORT=3002
